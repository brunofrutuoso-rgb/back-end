#Podemos alinhar o nome dentro do número de caracteres que
desejamos
nome = input ('Qual é o seu nome?')
#Alinhamento para direita
print('prazer em conhece-lo {:>20}!'.format(nome))
#Alinhamento para a esquerda
nome = input ('Qual é o seu nome?')
print('prazer em conhece-lo {:<20}!'.format(nome))
#Alinhamento no centro
nome = input ('Qual é o seu nome?')
print('prazer em conhece-lo {:^20}!'.format(nome))
